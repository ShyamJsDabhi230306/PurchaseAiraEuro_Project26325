-- Create login for IIS Application Pool
CREATE LOGIN [IIS APPPOOL\FITR] FROM WINDOWS;

-- Switch to your database
USE [FITR_DC_Database];

-- Create user mapped to login
CREATE USER [IIS APPPOOL\FITR] 
FOR LOGIN [IIS APPPOOL\FITR];

-- Grant roles (choose one option)

-- 🔹 Option 1: Full control (for testing)
ALTER ROLE db_owner 
ADD MEMBER [IIS APPPOOL\FITR];

